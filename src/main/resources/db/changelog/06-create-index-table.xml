<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="06-create-index-table" author="midl">
        <createTable tableName="`index`">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="page_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="lemma_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="`rank`" type="FLOAT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="`index`" indexName="idx_page_id">
            <column name="page_id"/>
        </createIndex>
        <createIndex tableName="`index`" indexName="idx_lemma_id">
            <column name="lemma_id"/>
        </createIndex>
        <createIndex tableName="`index`" indexName="idx_rank">
            <column name="`rank`"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>