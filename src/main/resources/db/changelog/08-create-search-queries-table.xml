<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="08-create-search-queries-table" author="midl">
        <createTable tableName="search_query_logs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="username" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="query" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="site_url" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="search_time" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="results_count" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="clicked" type="BOOLEAN">
                <constraints nullable="true"/>
            </column>
            <column name="response_time_ms" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="success" type="BOOLEAN">
                <constraints nullable="true"/>
            </column>
            <column name="error_message" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
            <column name="user_ip" type="VARCHAR(45)">
                <constraints nullable="true"/>
            </column>
            <column name="user_agent" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
            <column name="advanced_search" type="BOOLEAN">
                <constraints nullable="true"/>
            </column>
            <column name="filters" type="VARCHAR(1000)">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex tableName="search_query_logs" indexName="idx_search_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="search_query_logs" indexName="idx_search_query">
            <column name="query"/>
        </createIndex>
        <createIndex tableName="search_query_logs" indexName="idx_search_timestamp">
            <column name="search_time"/>
        </createIndex>
        <createIndex tableName="search_query_logs" indexName="idx_search_site">
            <column name="site_url"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
