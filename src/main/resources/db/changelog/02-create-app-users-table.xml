<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="02-create-app-users-table" author="midl">
        <createTable tableName="app_users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="last_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(60)">
                <constraints nullable="false"/>
            </column>
            <column name="activation_token" type="VARCHAR(36)">
                <constraints nullable="true" unique="true"/>
            </column>
            <column name="reset_token" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="locked_until" type="DATETIME(6)">
                <constraints nullable="true"/>
            </column>
            <column name="account_expired_at" type="DATETIME(6)">
                <constraints nullable="true"/>
            </column>
            <column name="credentials_expired_at" type="DATETIME(6)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME(6)">
                <constraints nullable="true"/>
            </column>
            <column name="last_login_at" type="DATETIME(6)">
                <constraints nullable="true"/>
            </column>
            <column name="failed_attempts" type="INT">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex tableName="app_users" indexName="idx_username">
            <column name="username"/>
        </createIndex>
        <createIndex tableName="app_users" indexName="idx_email">
            <column name="email"/>
        </createIndex>
        <createIndex tableName="app_users" indexName="idx_activation_token">
            <column name="activation_token"/>
        </createIndex>
        <createIndex tableName="app_users" indexName="idx_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
